{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memora",
  "version": "0.1.0",
  "identifier": "com.memora.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Memora",
        "width": 680,
        "height": 480,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true
      },
      {
        "label": "tray",
        "title": "Memora",
        "url": "index.html?window=tray",
        "width": 400,
        "height": 580,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "acceptFirstMouse": true,
        "skipTaskbar": true,
        "shadow": true,
        "center": false
      },
      {
        "label": "quick-paste",
        "title": "Memora Quick Paste",
        "url": "index.html?window=quick-paste",
        "width": 680,
        "height": 480,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "acceptFirstMouse": true,
        "skipTaskbar": true,
        "center": false
      },
      {
        "label": "settings",
        "title": "Memora Settings",
        "url": "index.html?window=settings",
        "width": 720,
        "height": 560,
        "minWidth": 640,
        "minHeight": 480,
        "visible": false,
        "decorations": true,
        "center": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "10.15"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3NUU4OUM0RjlCRkE4NjIKUldSaXFMLzV4SWxldDh6WjNocm9TSWJ2Vkh5NEYrZlUvb2FDb0FGRFlwamRVU2IwNUdDSEd0dC8K",
      "endpoints": [
        "https://github.com/ishola11/memora/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
