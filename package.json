{
  "name": "memora",
  "version": "0.1.9",
  "private": true,
  "description": "Your personal cross-device memory",
  "scripts": {
    "dev": "npm run dev --workspace=@memora/desktop",
    "build": "npm run build --workspace=@memora/desktop",
    "tauri": "npm run tauri --workspace=@memora/desktop",
    "generate:updater-keys": "powershell -ExecutionPolicy Bypass -File scripts/generate-updater-keys.ps1",
    "sync:updater-pubkey": "node scripts/sync-updater-pubkey.mjs",
    "copy:updater-key": "powershell -ExecutionPolicy Bypass -File scripts/copy-updater-private-key.ps1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  }
}
